# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (uncomment if using Go modules)
# vendor/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PHP
vendor/
composer.lock

# Docker
.dockerignore

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log

# Environment variables — never commit real credentials
.env
.env.local
.env.production
.env.staging
.env.*.local
# Keep .env.example committed (it has safe placeholder values)

# Temporary files
*.tmp
*.temp

# Kubernetes
kubeconfig

# Windows packaging — release artifacts (published via GitHub Releases, not committed)
docker-labs-*.zip
docker-labs-setup-*.exe
packaging/staging/
# go.sum NO se ignora — se necesita en repo para cache de GitHub Actions

# Go build output (launcher)
launcher/docker-labs-launcher
launcher/docker-labs-launcher.exe

# Launcher — artefactos Python de fase anterior (reemplazados por Go)
# Mantenidos localmente para referencia, excluidos del repositorio.
launcher/*.py
launcher/tests/
launcher/requirements-build.txt
launcher/__pycache__/