# Prometheus + Grafana — variables de entorno
# Copia este archivo como .env y cambia los valores antes de levantar en producción.
# En entorno local/lab los valores por defecto son suficientes.
# Grafana solicita cambio de contraseña en el primer inicio de sesión.

GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
